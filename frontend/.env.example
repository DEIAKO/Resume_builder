# Resume Landing Environment Variables

# Port for local development (not used in Vercel production)
PORT=3000

# Base path for the application
# Use "/" for root deployment
# Use "/resume" if deploying to a subdomain like your-site.com/resume
BASE_PATH=/

# API Configuration (if you have a backend)
# VITE_API_URL=https://api.yourdomain.com
# VITE_API_BASE_PATH=/api
